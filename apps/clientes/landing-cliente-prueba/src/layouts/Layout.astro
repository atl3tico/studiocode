---
interface Props {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
}

const {
  title = 'StudioCode — Web profesional para tu negocio local',
  description = 'Diseño y desarrollo de webs profesionales, subvencionables y adaptadas a móvil.',
  url = 'https://studiocode.example/',
  image = '/images/workspace.png',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Preload LCP image to improve LCP priority -->
    <link rel="preload" as="image" href="/images/hero-character.webp" />
    <!-- Preload Google Fonts stylesheet to avoid render-blocking; onload switches to stylesheet -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=Syne:wght@600;800&display=swap" onload="this.rel='stylesheet'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=Syne:wght@600;800&display=swap" rel="stylesheet" />
    </noscript>

    <style is:global>
      :root { --purple: #6B46E5; --purple-dark: #4B2EB5; --orange: #F97316; --dark: #1A1030; --text: #2D2545; --muted: #6B6080; --bg: #FAFAF8; --border: #E5E0F5; }
      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
      html{scroll-behavior:smooth}
      body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden}
      header{position:sticky;top:0;z-index:100;background:rgba(250,250,248,0.9);backdrop-filter:blur(8px);border-bottom:1px solid var(--border)}
      nav{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:14px 5%}
      .container{max-width:1100px;margin:0 auto}
      main{min-height:60vh;padding:48px 5%}
      footer{background:transparent;padding:40px 5%}
    </style>

    <!-- Schema.org structured data -->
    <script type="application/ld+json">
      {"@context":"https://schema.org","@graph":[{"@type":"Organization","name":"StudioCode","url":"https://studiocode.example/","logo":"https://studiocode.example/images/workspace.png","sameAs":[]},{"@type":"WebSite","url":"https://studiocode.example/","name":"StudioCode","description":"Diseño y desarrollo de webs profesionales"}]}
    </script>
  </head>

  <body>
    <header role="banner">
      <nav role="navigation" aria-label="Main navigation">
        <a href="/" class="nav-logo" aria-label="StudioCode home">Studio<span>Code</span></a>
        <ul class="nav-links" role="menubar">
          <li role="none"><a role="menuitem" href="#planes">Planes</a></li>
          <li role="none"><a role="menuitem" href="#features">Características</a></li>
          <li role="none"><a role="menuitem" href="#subvenciones">Subvenciones</a></li>
          <li role="none"><a role="menuitem" href="#proceso">Cómo funciona</a></li>
          <li role="none"><a role="menuitem" href="#faq">FAQ</a></li>
          <li role="none"><a role="menuitem" href="#contacto">Empezar</a></li>
        </ul>
      </nav>
    </header>

    <main id="main" role="main">
      <slot />
    </main>

    <footer role="contentinfo">
      <div class="container" style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:32px;align-items:start">
        <div>
          <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem">Studio<span style="background:var(--purple);padding:2px 8px;border-radius:6px;color:#fff;margin-left:8px">Code</span></div>
          <p style="color:var(--muted);margin-top:10px;max-width:300px">Diseñamos webs que trabajan por ti. Rápidas, bonitas y subvencionables. Para negocios reales con ganas de crecer en internet.</p>
        </div>
        <div>
          <h4 style="margin-bottom:8px;font-size:0.9rem;color:var(--muted)">Planes</h4>
          <a href="#planes">Web Presencia</a><br />
          <a href="#planes">Web Negocio + CRM</a><br />
          <a href="#planes">Tienda Online</a>
        </div>
        <div>
          <h4 style="margin-bottom:8px;font-size:0.9rem;color:var(--muted)">Info</h4>
          <a href="#features">Características</a><br />
          <a href="#subvenciones">Subvenciones</a><br />
          <a href="#proceso">Cómo funciona</a>
        </div>
        <div>
          <h4 style="margin-bottom:8px;font-size:0.9rem;color:var(--muted)">Contacto</h4>
          <a href="https://wa.me/34600000000">WhatsApp</a><br />
          <a href="mailto:hola@studiocode.es">Email</a><br />
          <a href="/aviso-legal">Aviso legal</a><br />
          <a href="/privacidad">Privacidad</a><br />
          <a href="/cookies">Cookies</a>
        </div>
      </div>
      <div style="border-top:1px solid var(--border);padding:18px 5%;text-align:center;color:var(--muted);font-size:0.9rem">© 2026 StudioCode — Diseño web profesional en Madrid</div>
    </footer>

    <script>
      // Small helpers: reveal animate-in elements
      if (typeof window !== 'undefined') {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12 });
        document.querySelectorAll('.animate-in').forEach(el => observer.observe(el));
      }
    </script>
  </body>
</html>
