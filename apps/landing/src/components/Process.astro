---
const steps = [
  {
    num: '1',
    title: 'Hablamos',
    desc: '15 minutos por WhatsApp o videollamada. Entendemos tu negocio y te recomendamos el plan ideal.',
  },
  {
    num: '2',
    title: 'Propuesta',
    desc: 'En 24h te enviamos presupuesto detallado y confirmamos si puedes subvencionar la web.',
  },
  {
    num: '3',
    title: 'Diseñamos',
    desc: 'Creamos tu web. Tú revisas y apruebas. Sin tecnicismos, sin sorpresas.',
  },
  {
    num: '4',
    title: '¡Online!',
    desc: 'Tu web está lista. Te formamos en 30 minutos para que puedas gestionarla tú mismo.',
  },
];
---

<section class="section" id="proceso">
  <div class="section-wrap">
    <div class="animate-in" style="text-align:center;">
      <div class="section-label">Cómo funciona</div>
      <h2 class="section-title" style="margin:0 auto;">
        De la idea a tu web<br />en menos de 2 semanas
      </h2>
    </div>

    <div class="process-steps">
      {steps.map((s) => (
        <div class="step animate-in">
          <div class="step-num">{s.num}</div>
          <div class="step-title">{s.title}</div>
          <div class="step-desc">{s.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
section { background: #ffffff; }
.process-steps {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 0;
  margin-top: 48px;
  max-width: 1100px;
  position: relative;
}
.process-steps::before {
  content: '';
  position: absolute;
  top: 32px; left: 5%; right: 5%;
  height: 1.5px;
  background: linear-gradient(90deg, transparent, var(--purple), var(--orange), transparent);
  pointer-events: none;
}

.step { text-align: center; padding: 0 16px; position: relative; }

.step-num {
  width: 64px; height: 64px;
  border-radius: 50%;
  background: white;
  border: 2px solid var(--border);
  font-family: 'Fraunces', serif;
  font-size: 1.3rem;
  font-weight: 900;
  color: var(--purple);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
  position: relative;
  z-index: 2;
  transition: background 0.2s, border-color 0.2s;
}
.step:hover .step-num { background: var(--purple); color: white; border-color: var(--purple); }

.step-title { font-family: 'Fraunces', serif; font-weight: 700; font-size: 1rem; margin-bottom: 8px; color: var(--dark); }
.step-desc  { font-size: 0.86rem; color: var(--muted); line-height: 1.6; }
</style>
