---
const planLinks = [
  { href: '#planes', label: 'Web Presencia' },
  { href: '#planes', label: 'Web Negocio + CRM' },
  { href: '#planes', label: 'Tienda Online' },
];

const infoLinks = [
  { href: '#features',     label: 'Características' },
  { href: '#subvenciones', label: 'Subvenciones' },
  { href: '#proceso',      label: 'Cómo funciona' },
  { href: '#faq',          label: 'Preguntas frecuentes' },
];

const contactLinks = [
  { href: 'https://wa.me/34600000000', label: '💬 WhatsApp', external: true },
  { href: 'mailto:hola@studiocode.es', label: '📧 Email',    external: false },
  { href: '#',                          label: '📅 Calendly', external: false },
  { href: '#',                          label: 'Aviso legal', external: false },
  { href: '#',                          label: 'Privacidad',  external: false },
];
---

<footer>
  <div class="footer-inner">

    <div class="footer-brand">
      <div class="footer-brand-name">Studio<span>Code</span></div>
      <p class="footer-desc">
        Diseñamos webs que trabajan por ti. Rápidas, bonitas y subvencionables.
        Para negocios reales con ganas de crecer en internet.
      </p>
    </div>

    <div class="footer-col">
      <h4>Planes</h4>
      {planLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>

    <div class="footer-col">
      <h4>Info</h4>
      {infoLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>

    <div class="footer-col">
      <h4>Contacto</h4>
      {contactLinks.map((l) => (
        <a
          href={l.href}
          target={l.external ? '_blank' : undefined}
          rel={l.external ? 'noopener noreferrer' : undefined}
        >
          {l.label}
        </a>
      ))}
    </div>

  </div>

  <div class="footer-bottom">
    <span class="footer-bottom-logo">StudioCode</span>
    <span>© 2026 StudioCode · Diseño web profesional en Madrid</span>
    <span>Hecho con 💜 en Madrid</span>
  </div>
</footer>

<style>
footer {
  background: #110B24;
  color: rgba(255,255,255,0.45);
  padding: 48px 5% 32px;
}

.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 40px;
  margin-bottom: 40px;
}

.footer-brand-name {
  font-family: 'Fraunces', serif;
  font-weight: 900;
  font-size: 1.2rem;
  color: white;
  margin-bottom: 10px;
}
.footer-brand-name span {
  background: var(--purple);
  padding: 1px 7px;
  border-radius: 5px;
  font-size: 0.9rem;
}

.footer-desc { font-size: 0.85rem; line-height: 1.65; max-width: 260px; }

.footer-col h4 {
  font-family: 'Fraunces', serif;
  font-weight: 700;
  font-size: 0.85rem;
  color: white;
  margin-bottom: 16px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.footer-col a {
  display: block;
  color: rgba(255,255,255,0.45);
  text-decoration: none;
  font-size: 0.87rem;
  margin-bottom: 10px;
  transition: color 0.2s;
}
.footer-col a:hover { color: white; }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
  padding-top: 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  font-size: 0.82rem;
  max-width: 1100px;
  margin: 0 auto;
}
.footer-bottom-logo { font-family: 'Fraunces', serif; font-weight: 700; color: white; font-size: 0.95rem; }

@media (max-width: 768px) {
  .footer-inner { grid-template-columns: 1fr 1fr; }
  .footer-bottom { flex-direction: column; text-align: center; }
}
</style>
