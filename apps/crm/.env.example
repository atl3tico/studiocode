# StudioCode CRM - Environment Variables
# Copy this file to .env and fill in the values

# Base path for SvelteKit (leave empty for root deployment)
BASE_PATH=

# Future: API/backend connection
# API_URL=https://api.studiocode.es
# API_KEY=

# Future: Authentication provider
# AUTH_SECRET=
# AUTH_PROVIDER_ID=
# AUTH_PROVIDER_SECRET=

# Future: Database
# DATABASE_URL=

# Future: Email/notification services
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Future: Calendar integration (Cal.com / Calendly)
# CALENDAR_API_KEY=
# CALENDAR_WEBHOOK_SECRET=

# Future: WhatsApp Business API
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_ID=
