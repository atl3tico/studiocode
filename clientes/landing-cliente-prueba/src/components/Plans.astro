---
const plans = [
  {
    icon: '🌐',
    name: 'Web Presencia',
    tagline: 'Para quien quiere "estar en internet" hoy mismo',
    price: '299€',
    priceUnit: 'pago único',
    recurring: 'Sin cuotas mensuales',
    featured: false,
    badge: null,
    features: [
      'Hasta 5 páginas profesionales',
      'Diseño adaptado a tu imagen de marca',
      'Formulario de contacto y mapa',
      'Optimización SEO básica',
      'Dominio + hosting primer año incluido',
      'Adaptada a móvil y tablet',
      'Entrega en 7 días hábiles',
    ],
  },
  {
    icon: '🚀',
    name: 'Web Negocio + CRM',
    tagline: 'Para empresas de servicios que necesitan gestionar clientes',
    price: '349€',
    priceUnit: 'inicio',
    recurring: '+ 19€/mes soporte',
    featured: true,
    badge: '⭐ Más popular',
    features: [
      'Todo lo del plan Presencia',
      'CRM integrado para gestionar clientes',
      'Sistema de reservas o citas online',
      'Panel de administración sencillo',
      'Integración con Google Calendar',
      'Estadísticas mensuales por email',
      'Soporte prioritario por WhatsApp',
      'Actualizaciones de contenido incluidas',
    ],
  },
  {
    icon: '🛒',
    name: 'Tienda Online',
    tagline: 'La joya de la corona: vende mientras duermes',
    price: '599€',
    priceUnit: 'inicio',
    recurring: '+ 29€/mes soporte',
    featured: false,
    badge: '✦ Top Ventas',
    badgeClass: 'plan-badge-gold',
    features: [
      'Todo lo del plan Negocio',
      'Tienda online completa con pagos',
      'Subida de productos desde Excel/CSV',
      'Gestión automática de stock',
      'Integración con pasarela de pagos',
      'Facturas automáticas a clientes',
      'Emails de recuperación de carrito',
      'Subvencionable con Kit Digital 🎁',
    ],
  },
];
---

<section class="section" id="planes">
  <div class="plans-intro animate-in">
    <div class="section-label">Planes</div>
    <h2 class="section-title">
      Todo lo que necesitas,<br /><em>sin lo que no</em>
    </h2>
    <p class="plans-sub">
      Elige el plan que encaja con tu momento actual. Siempre puedes escalar después.
    </p>
  </div>

  <div class="plans-grid">
    {plans.map((plan) => (
      <div class={`plan-card animate-in${plan.featured ? ' featured' : ''}${plan.badgeClass === 'plan-badge-gold' ? ' gold' : ''}`}>
        {plan.badge && <div class={`plan-badge${plan.badgeClass ? ' ' + plan.badgeClass : ''}`}>{plan.badge}</div>}
        <div class="plan-icon">{plan.icon}</div>
        <div class="plan-name">{plan.name}</div>
        <div class="plan-tagline">{plan.tagline}</div>
        <div class="plan-price">
          <span class="price-main">{plan.price}</span>
          <span class="price-unit">{plan.priceUnit}</span>
        </div>
        <div class="price-recurring">{plan.recurring}</div>
        <ul class="plan-features">
          {plan.features.map((f) => <li>{f}</li>)}
        </ul>
        <a
          href="#contacto"
          class={`plan-btn ${plan.featured ? 'plan-btn-fill' : 'plan-btn-outline'}`}
        >
          Quiero esta web →
        </a>
      </div>
    ))}
  </div>
</section>

<style>
/* Plans section sits on white */
section { background: #ffffff; }

.plans-intro { text-align: center; margin-bottom: 56px; }
.plans-intro .section-title { margin: 0 auto; }
.plans-sub {
  color: var(--muted);
  font-size: 1.05rem;
  margin-top: 16px;
  max-width: 520px;
  margin-left: auto;
  margin-right: auto;
}

.plans-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  max-width: 1100px;
  margin: 0 auto;
}

.plan-card {
  background: white;
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 36px 32px;
  position: relative;
  transition: transform 0.25s, box-shadow 0.25s;
}
.plan-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 50px rgba(107,70,229,0.12);
}
.plan-card.featured {
  border-color: var(--purple);
  box-shadow: 0 0 0 4px rgba(107,70,229,0.08);
}

.plan-badge {
  position: absolute;
  top: -14px; left: 28px;
  background: var(--orange);
  color: white;
  font-size: 0.75rem;
  font-weight: 700;
  padding: 4px 14px;
  border-radius: 100px;
  letter-spacing: 0.05em;
}

.plan-badge-gold {
  background: linear-gradient(135deg, #92610a 0%, #c8860a 50%, #f5b731 100%);
  color: #fff;
  box-shadow: 0 2px 12px rgba(200,134,10,0.4);
  letter-spacing: 0.06em;
}

.plan-card.gold {
  border-color: #f5b731;
  box-shadow: 0 0 0 4px rgba(245,183,49,0.12);
}
.plan-card.gold:hover {
  box-shadow: 0 20px 50px rgba(200,134,10,0.18), 0 0 0 4px rgba(245,183,49,0.15);
}

.plan-icon     { font-size: 2.2rem; margin-bottom: 16px; }
.plan-name     { font-family: 'Fraunces', serif; font-size: 1.25rem; font-weight: 700; color: var(--dark); margin-bottom: 4px; }
.plan-tagline  { color: var(--muted); font-size: 0.88rem; margin-bottom: 24px; }

.plan-price    { display: flex; align-items: flex-end; gap: 6px; margin-bottom: 6px; }
.price-main    { font-family: 'Fraunces', serif; font-size: 2.6rem; font-weight: 900; color: var(--dark); line-height: 1; }
.price-unit    { color: var(--muted); font-size: 0.9rem; margin-bottom: 6px; }
.price-recurring { color: var(--orange); font-size: 0.88rem; font-weight: 600; margin-bottom: 28px; }

.plan-features { list-style: none; margin-bottom: 32px; }
.plan-features li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 7px 0;
  font-size: 0.9rem;
  border-bottom: 1px solid var(--border);
  color: var(--text);
}
.plan-features li:last-child { border-bottom: none; }
.plan-features li::before { content: '✓'; color: var(--purple); font-weight: 700; flex-shrink: 0; margin-top: 1px; }

.plan-btn {
  display: block;
  text-align: center;
  padding: 13px;
  border-radius: 10px;
  font-weight: 600;
  font-size: 0.93rem;
  text-decoration: none;
  transition: all 0.2s;
}
.plan-btn-outline { border: 1.5px solid var(--purple); color: var(--purple); }
.plan-btn-outline:hover { background: var(--purple); color: white; }
.plan-btn-fill { background: var(--purple); color: white; box-shadow: 0 4px 18px rgba(107,70,229,0.3); }
.plan-btn-fill:hover { background: var(--purple-dark); }
</style>
