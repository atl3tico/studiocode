# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@tudominio.com
EMAIL_NOTIFY=admin@tudominio.com

# Admin panel
ADMIN_PASSWORD=cambia_esto_en_produccion
ADMIN_SECRET=secreto_largo_de_al_menos_32_caracteres_aqui

# App
PUBLIC_SITE_URL=http://localhost:5173
PUBLIC_SITE_NAME=Tu Negocio

# Seguridad (Milestone 6)
# Orígenes permitidos para CORS en /api/* (separados por coma, vacío = permitir todos)
ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# Sentry — monitorización de errores
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Plausible Analytics
PUBLIC_PLAUSIBLE_DOMAIN=tudominio.com
