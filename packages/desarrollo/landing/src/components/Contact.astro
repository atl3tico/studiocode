---
const cards = [
  {
    icon: '💬',
    title: 'WhatsApp',
    desc: 'La forma más rápida. Te respondemos en menos de 2 horas en horario laboral.',
    href: 'https://wa.me/34600000000?text=Hola!%20Quiero%20información%20sobre%20una%20web',
  },
  {
    icon: '📧',
    title: 'Email',
    desc: 'hola@studiocode.es — Para consultas detalladas o adjuntar documentos.',
    href: 'mailto:hola@studiocode.es',
  },
  {
    icon: '📅',
    title: 'Videollamada',
    desc: 'Reserva 15 minutos. Analizamos tu caso y te decimos exactamente qué necesitas.',
    href: 'https://calendly.com/studiocode',
  },
];
---

<section class="contact-section" id="contacto">
  <div class="section-label" style="color:#A78BF5;">Contacto</div>
  <h2 class="section-title" style="color:white;margin:0 auto 12px;">¿Empezamos?</h2>
  <p class="contact-sub">Elige cómo prefieres hablar con nosotros. Sin compromisos.</p>

  <div class="contact-grid">
    {cards.map((c) => (
      <a
        class="contact-card"
        href={c.href}
        target={c.href.startsWith('http') ? '_blank' : undefined}
        rel={c.href.startsWith('http') ? 'noopener noreferrer' : undefined}
      >
        <div class="contact-card-icon">{c.icon}</div>
        <div class="contact-card-title">{c.title}</div>
        <div class="contact-card-desc">{c.desc}</div>
      </a>
    ))}
  </div>

  <!-- Form -->
  <div class="contact-form-wrap">
    <form id="contact-form">
      <div class="form-row">
        <input type="text"  name="name"  placeholder="Tu nombre"  required />
        <input type="email" name="email" placeholder="Tu email"   required />
      </div>
      <select name="plan">
        <option value="">¿Qué plan te interesa?</option>
        <option value="presencia">Web Presencia — 299€</option>
        <option value="negocio">Web Negocio + CRM — 349€ + 19€/mes</option>
        <option value="tienda">Tienda Online — 599€ + 29€/mes</option>
        <option value="subvencion">Quiero info sobre subvenciones</option>
      </select>
      <textarea name="message" placeholder="Cuéntanos brevemente sobre tu negocio..." rows="4"></textarea>
      <button type="submit" class="btn-primary" style="width:100%;font-size:1rem;padding:15px;">
        Enviar mensaje →
      </button>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('¡Gracias! Te contactamos en menos de 24h.');
    form.reset();
  });
</script>

<style>
.contact-section {
  background: var(--dark);
  padding: 90px 5%;
  text-align: center;
}

.contact-sub { color: rgba(255,255,255,0.5); margin-bottom: 40px; font-size: 1rem; }

.contact-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  justify-content: center;
}

.contact-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 28px 32px;
  text-align: left;
  width: 280px;
  text-decoration: none;
  color: white;
  transition: background 0.2s, border-color 0.2s, transform 0.2s;
}
.contact-card:hover {
  background: rgba(255,255,255,0.09);
  border-color: rgba(107,70,229,0.5);
  transform: translateY(-3px);
}
.contact-card-icon  { font-size: 1.8rem; margin-bottom: 12px; }
.contact-card-title { font-family: 'Fraunces', serif; font-weight: 700; font-size: 1rem; margin-bottom: 4px; }
.contact-card-desc  { font-size: 0.84rem; color: rgba(255,255,255,0.5); }

/* Form */
.contact-form-wrap {
  margin: 60px auto 0;
  max-width: 560px;
}

form { display: grid; gap: 14px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

input,
select,
textarea {
  padding: 14px 16px;
  border-radius: 10px;
  border: 1.5px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.06);
  color: white;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.2s;
  width: 100%;
}
input:focus,
select:focus,
textarea:focus { border-color: var(--purple); }

select option { background: #1A1030; color: white; }
textarea { resize: vertical; }

input::placeholder,
textarea::placeholder { color: rgba(255,255,255,0.4); }

@media (max-width: 520px) {
  .form-row { grid-template-columns: 1fr; }
}
</style>
