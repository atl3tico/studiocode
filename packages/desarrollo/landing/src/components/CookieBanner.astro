---

<div class="cookie-banner" id="cookie-banner" role="dialog" aria-label="Aviso de cookies">
  <div class="cookie-inner">
    <div class="cookie-text">
      <span class="cookie-icon">🍪</span>
      <p>
        Usamos cookies propias y de terceros para mejorar tu experiencia y analizar el tráfico.
        Puedes aceptarlas todas o gestionar tus preferencias.
        <a href="/cookies">Más información</a>
      </p>
    </div>
    <div class="cookie-btns">
      <button class="cookie-btn-reject" id="cookie-reject">Solo esenciales</button>
      <button class="cookie-btn-accept" id="cookie-accept">Aceptar todas</button>
    </div>
  </div>
</div>

<style>
.cookie-banner {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 999;
  width: min(680px, calc(100vw - 32px));
  background: white;
  border: 1.5px solid var(--border);
  border-radius: 16px;
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.12);
  padding: 20px 24px;
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.cookie-banner.hidden {
  opacity: 0;
  transform: translateX(-50%) translateY(16px);
  pointer-events: none;
}

.cookie-inner {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}

.cookie-text {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  flex: 1;
  min-width: 200px;
}

.cookie-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 1px; }

.cookie-text p {
  font-size: 0.88rem;
  color: var(--muted);
  line-height: 1.55;
  margin: 0;
}

.cookie-text a {
  color: var(--purple);
  text-decoration: underline;
  white-space: nowrap;
}

.cookie-btns {
  display: flex;
  gap: 10px;
  flex-shrink: 0;
}

.cookie-btn-reject {
  padding: 10px 18px;
  border-radius: 8px;
  border: 1.5px solid var(--border);
  background: transparent;
  color: var(--muted);
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
  white-space: nowrap;
}
.cookie-btn-reject:hover { border-color: var(--purple); color: var(--purple); }

.cookie-btn-accept {
  padding: 10px 18px;
  border-radius: 8px;
  border: none;
  background: var(--purple);
  color: white;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
  white-space: nowrap;
}
.cookie-btn-accept:hover { background: var(--purple-dark); }

@media (max-width: 480px) {
  .cookie-inner { flex-direction: column; align-items: stretch; }
  .cookie-btns { justify-content: flex-end; }
}
</style>

<script>
  const banner = document.getElementById('cookie-banner');
  const accepted = localStorage.getItem('cookies-consent');

  if (accepted) {
    banner?.classList.add('hidden');
  }

  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    localStorage.setItem('cookies-consent', 'all');
    banner?.classList.add('hidden');
  });

  document.getElementById('cookie-reject')?.addEventListener('click', () => {
    localStorage.setItem('cookies-consent', 'essential');
    banner?.classList.add('hidden');
  });
</script>
