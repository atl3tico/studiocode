# Site URL (update in astro.config.mjs too)
SITE_URL=https://example.com

# Negocio
BUSINESS_NAME=Mi Negocio
CONTACT_EMAIL=hola@example.com

# CRM (Pipedrive / HubSpot / Make / n8n — cualquier webhook)
CRM_WEBHOOK_URL=https://hooks.example.com/leads
CRM_PROVIDER=generic
CRM_API_KEY=

# Backup de leads en disco (montar volumen persistente en Coolify)
DATA_DIR=./data

# CMS Sanity (si se usa)
# PUBLIC_SANITY_PROJECT_ID=...
# PUBLIC_SANITY_DATASET=production
# SANITY_API_TOKEN=...

# Email automático (Fase 2 — Resend / Brevo)
# RESEND_API_KEY=...
# WEBHOOK_SECRET=...
