---
import Layout from '../layouts/Layout.astro'
import LeadForm from '../components/LeadForm.astro'
---
<Layout title="Web Presencia" description="Tu negocio en internet">
  <main class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-4">Bienvenido</h1>
    <p class="text-lg text-gray-600 mb-12">Descripción de tu negocio o servicio.</p>
    <LeadForm showCompany={true} showAppointment={true} submitLabel="Solicitar información" />
  </main>
</Layout>
